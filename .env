# AlphaForge — Local Development Config
# No Docker needed. Everything stored locally in the project folder.

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database (SQLite) ──────────────────────────────────────────────────────────
ALPHAFORGE_DB_URL=sqlite:///data/alphaforge.db

# ── Feature Store ──────────────────────────────────────────────────────────────
FEATURE_STORE_PATH=data/features

# ── MLflow (SQLite backend — silences FutureWarning about file store) ──────────
# Experiments stored in data/mlflow.db, artifacts in mlruns/
MLFLOW_TRACKING_URI=sqlite:///data/mlflow.db

# ── Redis (leave empty — uses in-memory cache for local dev) ───────────────────
REDIS_URL=
SIGNAL_CACHE_TTL_SECONDS=60

# ── Assets ─────────────────────────────────────────────────────────────────────
CRYPTO_ASSETS=["BTC/USDT","ETH/USDT","SOL/USDT"]
EQUITY_ASSETS=["SPY","QQQ"]

# ── Data ───────────────────────────────────────────────────────────────────────
CRYPTO_TIMEFRAME=1h
EQUITY_TIMEFRAME=1d
LOOKBACK_DAYS=365
FEATURE_WINDOW=60

# ── Model ──────────────────────────────────────────────────────────────────────
PREDICTION_HORIZONS=[1,5,20]
BATCH_SIZE=32
MAX_EPOCHS=50
LEARNING_RATE=0.001
EARLY_STOPPING_PATIENCE=10

# ── Promotion gates ────────────────────────────────────────────────────────────
MIN_AUC_ROC=0.55
MIN_SHARPE_RATIO=0.8
MAX_DRAWDOWN_PCT=0.20
MIN_INFORMATION_COEFFICIENT=0.03

# ── Binance (no API key needed for public OHLCV data) ─────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=