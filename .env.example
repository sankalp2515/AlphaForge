# AlphaForge Environment Configuration
# Copy to .env and fill in values

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (TimescaleDB)
ALPHAFORGE_DB_URL=postgresql://alphaforge:alphaforge@localhost:5433/alphaforge

# Redis
REDIS_URL=redis://localhost:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=alphaforge-v1

# Binance (optional — only needed for private endpoints)
# Public OHLCV data works without API keys
BINANCE_API_KEY=
BINANCE_SECRET=

# Model settings
PREDICTION_HORIZONS=[1,5,20]
FEATURE_WINDOW=60
BATCH_SIZE=64
MAX_EPOCHS=100

# Evaluation gates
MIN_AUC_ROC=0.55
MIN_SHARPE_RATIO=0.8
MAX_DRAWDOWN_PCT=0.20
MIN_INFORMATION_COEFFICIENT=0.03
